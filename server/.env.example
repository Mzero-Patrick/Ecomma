# Copy to server/.env and adjust for your XAMPP MySQL setup
PORT=3000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ecomma

# Default admin (created on first server start if missing)
ADMIN_EMAIL=admin@ecomma.rw
ADMIN_PASSWORD=EcommaAdmin2026
ADMIN_NAME=Platform Admin

# Payments — demo mode simulates MTN MoMo / Airtel Money approval locally
PAYMENT_DEMO_MODE=true

# Live MTN MoMo (optional — for production integration)
# MTN_MOMO_SUBSCRIPTION_KEY=
