# Copy to server/.env and adjust for your XAMPP MySQL setup
PORT=3000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ecomma

# Default admin (created on first server start if missing)
ADMIN_EMAIL=admin@ecomma.rw
ADMIN_PASSWORD=EcommaAdmin2026
ADMIN_NAME=Platform Admin

# Payments — demo mode simulates MTN MoMo / Airtel Money approval locally
PAYMENT_DEMO_MODE=true

# Cloud MySQL (required for Vercel — see DEPLOY.md)
# DB_HOST=your-host.railway.app
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=railway
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=false
# Or: DATABASE_URL=mysql://user:pass@host:3306/dbname