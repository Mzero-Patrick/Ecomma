{
  "version": 2,
  "rewrites": [
    { "source": "/api/ping", "destination": "/api/ping.js" },
    { "source": "/api/db-test", "destination": "/api/db-test.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    },
    "api/ping.js": {
      "maxDuration": 10
    }
  }
}
